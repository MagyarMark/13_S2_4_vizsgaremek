<Page
    x:Class="SMadmin.Views.UsersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SMadmin.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Felhasználók kezelése"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,24"/>

        <Grid Grid.Row="1" Margin="0,0,0,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                    PlaceholderText="Keresés (név, email, felhasználónév)..."/>

            <ComboBox x:Name="RoleFilterBox"
                     Grid.Column="1"
                     Header="Szerepkör"
                     HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Összes" IsSelected="True"/>
                <ComboBoxItem Content="Tanár" Tag="tanar"/>
                <ComboBoxItem Content="Diák" Tag="diak"/>
                <ComboBoxItem Content="Admin" Tag="admin"/>
            </ComboBox>

            <Button Grid.Column="2"
                   Content="Keresés"
                   Click="SearchButton_Click"
                   Style="{StaticResource AccentButtonStyle}"
                   VerticalAlignment="Bottom"/>
        </Grid>

        <InfoBar x:Name="ErrorBar"
                Grid.Row="2"
                IsOpen="False"
                Severity="Error"
                Margin="0,0,0,8"/>

        <Grid Grid.Row="3">
            <ProgressRing x:Name="LoadingRing"
                         IsActive="False"
                         Width="50" Height="50"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

            <ListView x:Name="UsersListView"
                     Visibility="Visible">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:User">
                        <Grid Padding="12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <PersonPicture DisplayName="{x:Bind FullName}" Width="40" Height="40"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind FullName}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind Email}" Opacity="0.7" FontSize="12"/>
                                <TextBlock Text="{x:Bind Username}" Opacity="0.7" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Szerepkör:" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind Role}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <Border Grid.Column="3"
                                   Background="{ThemeResource SystemFillColorSuccessBrush}"
                                   CornerRadius="4"
                                   Padding="8,4"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   Visibility="{x:Bind Active}">
                                <TextBlock Text="Aktív" FontSize="12" FontWeight="SemiBold"/>
                            </Border>

                            <Button Grid.Column="4"
                                   Content="Törlés"
                                   Tag="{x:Bind Id}"
                                   Click="DeleteUser_Click"
                                   Style="{StaticResource SubtleButtonStyle}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="4" Margin="0,16,0,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="PrevButton" Content="Előző" Click="PrevPage_Click"/>

            <StackPanel Grid.Column="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Spacing="8">
                <TextBlock x:Name="PageInfo" VerticalAlignment="Center"/>
                <TextBlock Text="|" Opacity="0.5" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalInfo" VerticalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="NextButton" Grid.Column="2" Content="Következő" Click="NextPage_Click"/>
        </Grid>
    </Grid>
</Page>
