<Page
    x:Class="SMadmin.Views.SubmissionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SMadmin.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Beadások kezelése"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,24"/>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <ComboBox x:Name="StatusFilterBox"
                     Header="Státusz szerinti szűrés"
                     HorizontalAlignment="Left"
                     MinWidth="200"
                     SelectionChanged="StatusFilter_Changed">
                <ComboBoxItem Content="Összes" IsSelected="True"/>
                <ComboBoxItem Content="Beküldve" Tag="beküldve"/>
                <ComboBoxItem Content="Elfogadva" Tag="elfogadva"/>
                <ComboBoxItem Content="Elutasítva" Tag="elutasítva"/>
                <ComboBoxItem Content="Értékelt" Tag="ertekelt"/>
                <ComboBoxItem Content="Értékelve" Tag="ertékelt"/>
                <ComboBoxItem Content="Javítás alatt" Tag="javitas_alatt"/>
            </ComboBox>
        </Grid>

        <InfoBar x:Name="ErrorBar"
                Grid.Row="2"
                IsOpen="False"
                Severity="Error"
                Margin="0,0,0,8"/>

        <Grid Grid.Row="3">
            <ProgressRing x:Name="LoadingRing"
                         IsActive="False"
                         Width="50" Height="50"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

            <ListView x:Name="SubmissionsListView"
                     Visibility="Visible">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Submission">
                        <Grid Padding="12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind TaskName}" FontWeight="SemiBold" FontSize="16"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Opacity="0.6" FontSize="11">
                                        <Run Text="Diák:"/>
                                        <Run Text="{x:Bind StudentName}"/>
                                    </TextBlock>
                                    <TextBlock Text="•" Opacity="0.4" FontSize="11"/>
                                    <TextBlock Opacity="0.6" FontSize="11">
                                        <Run Text="Tanár:"/>
                                        <Run Text="{x:Bind TeacherName}"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{x:Bind SubmittedAt}" Opacity="0.6" FontSize="11"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Státusz:" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind Status}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Pontszám:" FontSize="11" Opacity="0.6"/>
                                <TextBlock FontWeight="SemiBold">
                                    <Run Text="{x:Bind Score}"/>
                                    <Run Text="/"/>
                                    <Run Text="100"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="Jegy:" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind Grade}"
                                          FontWeight="Bold"
                                          FontSize="20"
                                          HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="4" Margin="0,16,0,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="PrevButton" Content="Előző" Click="PrevPage_Click"/>

            <StackPanel Grid.Column="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Spacing="8">
                <TextBlock x:Name="PageInfo" VerticalAlignment="Center"/>
                <TextBlock Text="|" Opacity="0.5" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalInfo" VerticalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="NextButton" Grid.Column="2" Content="Következő" Click="NextPage_Click"/>
        </Grid>
    </Grid>
</Page>
