<Page
    x:Class="SMadmin.Views.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SMadmin.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Projektek kezelése"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,24"/>

        <Grid Grid.Row="1" Margin="0,0,0,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                    PlaceholderText="Keresés (projekt név, leírás)..."/>

            <ComboBox x:Name="StatusFilterBox"
                     Grid.Column="1"
                     Header="Státusz"
                     HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Összes" IsSelected="True"/>
                <ComboBoxItem Content="Aktív" Tag="aktiv"/>
                <ComboBoxItem Content="Befejezett" Tag="befejezett"/>
                <ComboBoxItem Content="Archivált" Tag="archivalt"/>
            </ComboBox>

            <Button Grid.Column="2"
                   Content="Keresés"
                   Click="SearchButton_Click"
                   Style="{StaticResource AccentButtonStyle}"
                   VerticalAlignment="Bottom"/>
        </Grid>

        <InfoBar x:Name="ErrorBar"
                Grid.Row="2"
                IsOpen="False"
                Severity="Error"
                Margin="0,0,0,8"/>

        <Grid Grid.Row="3">
            <ProgressRing x:Name="LoadingRing"
                         IsActive="False"
                         Width="50" Height="50"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

            <ListView x:Name="ProjectsListView"
                     Visibility="Visible">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Project">
                        <Grid Padding="12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="16"/>
                                <TextBlock Text="{x:Bind Description}"
                                          Opacity="0.7"
                                          FontSize="12"
                                          TextWrapping="Wrap"
                                          MaxLines="2"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Opacity="0.6" FontSize="11">
                                        <Run Text="Létrehozta:"/>
                                        <Run Text="{x:Bind CreatorName}"/>
                                    </TextBlock>
                                    <TextBlock Text="•" Opacity="0.4" FontSize="11"/>
                                    <TextBlock Text="{x:Bind CreatedAt}" Opacity="0.6" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Státusz:" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind Status}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4" Margin="0,0,12,0">
                                <TextBlock Text="Határidő:" FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{x:Bind Deadline}" FontWeight="SemiBold"/>
                            </StackPanel>

                            <Button Grid.Column="3"
                                   Content="Törlés"
                                   Tag="{x:Bind Id}"
                                   Click="DeleteProject_Click"
                                   Style="{StaticResource SubtleButtonStyle}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="4" Margin="0,16,0,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="PrevButton" Content="Előző" Click="PrevPage_Click"/>

            <StackPanel Grid.Column="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Spacing="8">
                <TextBlock x:Name="PageInfo" VerticalAlignment="Center"/>
                <TextBlock Text="|" Opacity="0.5" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalInfo" VerticalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="NextButton" Grid.Column="2" Content="Következő" Click="NextPage_Click"/>
        </Grid>
    </Grid>
</Page>
