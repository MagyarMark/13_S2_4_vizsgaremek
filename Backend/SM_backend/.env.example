# adatbázis
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_ENV=production

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# email (nodemailer)
EMAIL_USER=
EMAIL_PASS=

# CORS
CORS_ORIGINS=https://tedomained.com

# socket.io
SOCKET_ALLOWED_ORIGINS=https://tedomained.com

# email megerősítő URL-ek (frontend útvonalak)
EMAIL_VERIFICATION_URL_BASE=https://tedomained.com/verify-email
ACCOUNT_REACTIVATION_URL_BASE=https://tedomained.com/reactivate-account

# szerver
PORT=3000
NODE_ENV=production
BIND_HOST=0.0.0.0

# rate limiting (max kérés per 15 perc per IP az auth végpontokon)
AUTH_RATE_LIMIT_MAX=100
